{
  "agentId": "my-agent",
  "agentName": "My Agent",
  "managerUrl": "http://localhost:3001",
  "authToken": "change-this-token",
  "executor": "local",
  "allowedPaths": ["/Users/me/projects/*"],
  "blockedPaths": ["/Users/me/.ssh"],
  "capabilities": ["no-gpu"],
  "dockerConfig": {
    "image": "ccrunner:latest",
    "memory": "8g",
    "cpus": "4",
    "extraMounts": [
      {
        "source": "/data/datasets",
        "target": "/datasets",
        "readonly": true
      }
    ]
  }
}
