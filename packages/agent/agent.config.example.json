{
  "agentId": "my-agent",
  "agentName": "My Agent",
  "managerUrl": "http://localhost:3001",
  "managerUrlSource": "https://raw.githubusercontent.com/your-org/CCManagerData/main/tunnel-url.txt",
  "executor": "local",
  "allowedPaths": ["/Users/me/projects/*"],
  "blockedPaths": ["/Users/me/.ssh"],
  "capabilities": ["no-gpu"],
  "dockerConfig": {
    "image": "ccmanager-runner:latest",
    "memory": "8g",
    "cpus": "4",
    "network": "bridge",
    "sessionsDir": "/home/me/.ccm-sessions",
    "extraMounts": [
      {
        "source": "/data/datasets",
        "target": "/datasets",
        "readonly": true
      }
    ]
  }
}
