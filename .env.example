# CCManager Environment Variables
# Copy this file to .env and fill in your values

# Claude Code Authentication (choose one)
# Option 1: OAuth Token (uses Pro/Max subscription)
CLAUDE_CODE_OAUTH_TOKEN=clt_xxxxxxxxxx

# Option 2: API Key (pay-per-use)
# ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxx

# Server Configuration
PORT=3001
HOST=127.0.0.1
NODE_ENV=development

# Data directory (default: ./data)
# DATA_PATH=/path/to/CCManagerData

# Production mode (serve frontend static files)
# SERVE_STATIC=true
# STATIC_PATH=/path/to/packages/web/dist

# Voice transcription (optional, OpenAI-compatible Whisper API)
# Default: Groq (fast & free). Also supports OpenAI, Azure, etc.
# WHISPER_API_URL=https://api.groq.com/openai/v1
# WHISPER_API_KEY=gsk_xxxxxxxxxx
# WHISPER_MODEL=whisper-large-v3-turbo

# Device tokens are managed via CLI:
#   ccmng token create --name "MacBook Pro"
#   ccmng token list
#   ccmng token revoke <id>
