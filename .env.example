# CCManager Environment Variables
# Copy this file to .env and fill in your values

# Claude Code Authentication (choose one)
# Option 1: Setup Token (uses Pro/Max subscription)
CLAUDE_CODE_OAUTH_TOKEN=clt_xxxxxxxxxx

# Option 2: API Key (pay-per-use)
# ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxx

# Whisper API Configuration (for voice transcription)
# Supports OpenAI-compatible APIs
# Examples:
#   OpenAI:      https://api.openai.com/v1
#   Azure:       https://xxx.openai.azure.com/openai/deployments/whisper
#   Third-party: https://your-platform.com/v1
WHISPER_API_URL=https://api.openai.com/v1
WHISPER_API_KEY=sk-xxxxxxxxxx
WHISPER_MODEL=whisper-1

# Server Configuration
PORT=3001
NODE_ENV=development
