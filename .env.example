# CCManager Environment Variables
# Copy this file to .env and fill in your values

# Claude Code Authentication (choose one)
# Option 1: Setup Token (uses Pro/Max subscription)
CLAUDE_CODE_OAUTH_TOKEN=clt_xxxxxxxxxx

# Option 2: API Key (pay-per-use)
# ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxx

# Groq API Configuration (for voice transcription)
# Get your API key from https://console.groq.com/keys
# Models: whisper-large-v3-turbo (fast, $0.04/hr) or whisper-large-v3 (accurate, $0.111/hr)
GROQ_API_KEY=gsk_xxxxxxxxxx
GROQ_MODEL=whisper-large-v3-turbo

# Server Configuration
PORT=3001
HOST=127.0.0.1
NODE_ENV=development

# Device tokens are managed via CLI:
#   ccmng token create --name "MacBook Pro"
#   ccmng token list
#   ccmng token revoke <id>
